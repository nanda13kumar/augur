# ─────────────────────────────────────────────────────────────────────────────
#  Augur frontend configuration  (copy to .env for local `npm run dev`)
#  For Docker, set these in the ROOT .env instead — compose passes them through.
# ─────────────────────────────────────────────────────────────────────────────

# Dev-server port and the backend it proxies /api to
FRONTEND_PORT=3100
BACKEND_PORT=8100

# Branding (overrides config.js defaults at build time)
# VITE_APP_NAME=Augur
# VITE_APP_TAGLINE=Predictive Anomaly Detection

# Behaviour
# VITE_POLL_INTERVAL_MS=30000
# VITE_DEFAULT_WINDOW_DAYS=30

# Only needed if the backend is on a different host/origin than the proxy target
# VITE_API_PROXY=http://localhost:8100
