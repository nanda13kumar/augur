# ─────────────────────────────────────────────────────────────────────────────
#  Augur backend configuration  (copy to .env)
#  Every value here maps to a field in backend/config.py and is optional.
# ─────────────────────────────────────────────────────────────────────────────

# Port the API binds to
BACKEND_PORT=8100

# Data mode:  auto | live | demo
#   auto → use Prometheus if reachable, otherwise fall back to demo data
#   live → require Prometheus (no fallback)
#   demo → synthetic data only (no Prometheus needed)
DATA_MODE=auto

# ── Prometheus ───────────────────────────────────────────────────────────────
# Point Augur at your workspace. Leave blank to run in demo mode.
PROMETHEUS_URL=
# Optional auth (basic or bearer)
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=
PROMETHEUS_BEARER_TOKEN=

# ── Discovery ────────────────────────────────────────────────────────────────
# Comma-separated label candidates used to find services (first match wins).
# DISCOVERY_LABELS=["service","application","job"]
# Only show these services (JSON list). Leave empty to show all.
# DISCOVERY_INCLUDE=[]
# Hide these (substring match).
# DISCOVERY_EXCLUDE=["prometheus","grafana","alertmanager","node-exporter"]
# How often to rescan Prometheus for new services (seconds)
DISCOVERY_REFRESH_SECONDS=60

# ── Prophet / detection ──────────────────────────────────────────────────────
PROPHET_ENABLED=true
PROPHET_INTERVAL_WIDTH=0.99
MODEL_CACHE_TTL_SECONDS=900

# Default analysis window shown in the UI
DEFAULT_WINDOW_DAYS=30

LOG_LEVEL=INFO
